<?xml version="1.0" encoding="utf-8"?>
<!--
    Item de slot horario del profesional.
    Cambios respecto a la versión anterior:
      1. Se elimina la dependencia de FlexboxLayout. La fila de badges (tipo + modalidad
         + aforo) pasa a LinearLayout vertical para que cada badge ocupe su propio
         renglón sin restricción de ancho — ninguna palabra se trunca.
      2. Se añade borde stroke negro usando MaterialCardView en lugar de CardView estándar.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/white"
    app:strokeColor="@color/black"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Franja horaria -->
        <TextView
            android:id="@+id/tvSlotHorario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/background"
            android:textSize="14sp"
            android:textStyle="bold"
            android:minWidth="100dp" />

        <!-- Info central: badge libre/ocupado o datos de sesión propia -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <!-- Badge LIBRE u OCUPADO -->
            <TextView
                android:id="@+id/tvSlotEstadoBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/badge_background"
                android:maxLines="1"
                android:visibility="gone" />

            <!-- Título de la sesión propia -->
            <TextView
                android:id="@+id/tvSlotTituloSesion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!--
                Badges en orientación VERTICAL: tipo, modalidad y aforo en renglones
                separados — sin dependencia externa y sin truncado de texto.
            -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tvSlotTipo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/badge_background"
                    android:maxLines="1"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvSlotModalidad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/badge_background"
                    android:maxLines="1"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvSlotAforo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/badge_background"
                    android:maxLines="1"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

        <!-- Botón cancelar sesión propia -->
        <ImageButton
            android:id="@+id/btnSlotCancelar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            app:tint="@color/background"
            android:visibility="gone"
            android:contentDescription="Cancelar sesión" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>