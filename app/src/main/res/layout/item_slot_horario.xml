<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_slot_horario"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <!-- Hora del slot -->
    <TextView
        android:id="@+id/tvHoraSlot"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/black"
        android:textSize="13sp"
        android:textStyle="bold" />

    <!-- Título de la sesión (solo visible si el slot está ocupado) -->
    <TextView
        android:id="@+id/tvTituloSesionSlot"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.5"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#555555"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Badge de estado LIBRE / OCUPADO -->
    <TextView
        android:id="@+id/tvEstadoSlot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_badge_rol"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:textColor="@color/white"
        android:textSize="10sp"
        android:textStyle="bold" />

</LinearLayout>