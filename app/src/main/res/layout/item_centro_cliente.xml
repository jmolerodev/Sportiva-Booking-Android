<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Badge de membresía activa -->
        <TextView
            android:id="@+id/badgeMembresia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Membresía Activa"
            android:textColor="@color/background"
            android:textStyle="bold"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvNombreCentro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvDireccionCentro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvTelefonoCentro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:textSize="13sp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnVerCentro"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Ver Centro"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="13sp"
            android:backgroundTint="#322E2E"
            app:cornerRadius="10dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>